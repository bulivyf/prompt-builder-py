# Provider selection:
#   local | openai | anthropic | google | grok | huggingface
#   OR any custom provider name you define via PROVIDER_<NAME>_* env vars (see bottom).
#
# Notes:
# - Default provider is local.

LLM_PROVIDER=local

# -------------------------
# Local GGUF (llama-cpp)
# -------------------------
LOCAL_MODEL_PATH=<YourDrive>:<Your dir>/LLM/models/model.gguf
LOCAL_MODEL_N_CTX=4096
LOCAL_MODEL_N_THREADS=16
LOCAL_MODEL_NAME=local-gguf

# -------------------------
# OpenAI (Chat Completions)
# -------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Retries / safety defaults for OpenAI-compatible providers
OPENAI_MAX_TOKENS=900
OPENAI_MAX_RETRIES=6
OPENAI_BACKOFF_SECONDS=1.0
OPENAI_TIMEOUT_SECONDS=60

# -------------------------
# Anthropic
# -------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=1200

# -------------------------
# Google (Gemini)
# - Default uses the new google.genai SDK.
# - If you prefer google.generativeai, set LLM_PROVIDER=google_generativeai.
# -------------------------
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# -------------------------
# Grok (xAI) - OpenAI-compatible
# -------------------------
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-latest

# -------------------------
# Hugging Face Router - OpenAI-compatible
# -------------------------
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# -------------------------
# Generic providers (ANY OpenAI-compatible endpoint)
# Example: DeepSeek (OpenAI-compatible)
#
# LLM_PROVIDER=deepseek
# PROVIDER_DEEPSEEK_MODE=openai_compat
# PROVIDER_DEEPSEEK_API_KEY=
# PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# PROVIDER_DEEPSEEK_MODEL=deepseek-chat
# -------------------------

# Server
HOST=127.0.0.1
PORT=8012
